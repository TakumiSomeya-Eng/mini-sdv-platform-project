      },
      "targets": [
        {
          "datasource": { "type": "influxdb", "uid": "influxdb-sdv" },
          "query": "from(bucket: \"vehicle_telemetry\")\n  |> range(start: v.timeRangeStart, stop: v.timeRangeStop)\n  |> filter(fn: (r) => r._measurement == \"alpa_sim_eval\" and r._field == \"mean_reward\")\n  |> aggregateWindow(every: v.windowPeriod, fn: last)\n  |> yield(name: \"mean_reward\")",
          "refId": "A"
        }
      ]
